# ─── Base de datos (requerido) ─────────────────────────────────────────────────
# Local:   postgresql://usuario:contraseña@localhost:5432/minimarket
# Neon:    copiar la URL de conexión del dashboard en neon.tech
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/minimarket

# ─── JWT (requerido) ────────────────────────────────────────────────────────────
# IMPORTANTE: usar una cadena aleatoria larga (mínimo 32 caracteres)
# Generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_de_al_menos_32_caracteres
JWT_EXPIRES_IN=7d

# ─── Servidor ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── SSL de base de datos ───────────────────────────────────────────────────────
# true  → Neon / Supabase / cualquier PG remoto con SSL
# false → PostgreSQL local sin SSL
DB_SSL=false

# ─── CORS (solo si el frontend está en otro origen) ─────────────────────────────
# En LAN local dejar comentado. En producción cloud: URL del frontend.
# CORS_ORIGIN=https://mi-frontend.vercel.app

# ─── Email para recuperación de contraseña (opcional) ───────────────────────────
# Gmail requiere "Contraseña de aplicación" (no la contraseña normal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=contraseña-de-aplicacion-de-16-caracteres

# ─── API consulta DNI/RUC — decolecta.com (opcional) ────────────────────────────
APIS_PERU_TOKEN=tu-token-aqui
